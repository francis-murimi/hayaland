# sqlx macros and tests read this by default.
DATABASE_URL=postgres://hayaland:hayaland@127.0.0.1:5432/hayaland_test

# Application-specific config (overrides DATABASE_URL for the running API).
APP_DATABASE__URL=postgres://hayaland:hayaland@127.0.0.1:5432/hayaland
APP_DATABASE__MAX_CONNECTIONS=10
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=8080
APP_LOG__LEVEL=info
APP_AUTH__SECRET=change-me-in-production
APP_AUTH__TOKEN_EXPIRY_SECONDS=86400

# External SMTP server for transactional emails.
APP_EMAIL__SMTP_HOST=smtp.example.com
APP_EMAIL__SMTP_PORT=587
APP_EMAIL__SMTP_USERNAME=change-me
APP_EMAIL__SMTP_PASSWORD=change-me
APP_EMAIL__FROM_ADDRESS=noreply@hayaland.local
APP_EMAIL__FROM_NAME=Hayaland
APP_EMAIL__VERIFICATION_BASE_URL=https://app.hayaland.local
APP_EMAIL__VERIFICATION_TOKEN_EXPIRY_SECONDS=86400
APP_EMAIL__PASSWORD_RESET_TOKEN_EXPIRY_SECONDS=3600
APP_EMAIL__EMAIL_MAX_RETRIES=3
APP_EMAIL__EMAIL_RETRY_BASE_DELAY_MS=500
APP_EMAIL__EMAIL_RETRY_MAX_DELAY_MS=5000

# Deal timeout configuration (seconds).
APP_DEAL_TIMEOUTS__DRAFT_SECONDS=604800
APP_DEAL_TIMEOUTS__SUGGESTED_SECONDS=1209600
APP_DEAL_TIMEOUTS__PENDING_REVIEW_SECONDS=1209600
APP_DEAL_TIMEOUTS__NEGOTIATING_SECONDS=2592000
APP_DEAL_TIMEOUTS__AWAITING_PARTY_SECONDS=1209600
APP_DEAL_TIMEOUTS__TERMS_LOCKED_SECONDS=1209600
APP_DEAL_TIMEOUTS__COMMITTED_SECONDS=259200
APP_DEAL_TIMEOUTS__ON_HOLD_SECONDS=2592000
APP_DEAL_TIMEOUTS__DISPUTED_SECONDS=1209600

# Background deal timeout worker.
APP_DEAL_TIMEOUT_WORKER__ENABLED=true
APP_DEAL_TIMEOUT_WORKER__INTERVAL_SECONDS=300
APP_DEAL_TIMEOUT_WORKER__BATCH_SIZE=100

# Messaging encryption and pinning.
APP_MESSAGES__ENCRYPTION_KEY=base64-encoded-32-byte-key-change-me
APP_MESSAGES__MAX_PINNED_PER_CONVERSATION=5

# Trust-score calculation configuration.
APP_TRUST_SCORE__WEIGHTS__TRANSACTION_HISTORY=0.25
APP_TRUST_SCORE__WEIGHTS__REVIEW_RATINGS=0.20
APP_TRUST_SCORE__WEIGHTS__PROFILE_COMPLETENESS=0.10
APP_TRUST_SCORE__WEIGHTS__VERIFICATION_LEVEL=0.15
APP_TRUST_SCORE__WEIGHTS__RESPONSE_RATE=0.10
APP_TRUST_SCORE__WEIGHTS__DISPUTE_HISTORY=0.10
APP_TRUST_SCORE__WEIGHTS__LONGEVITY=0.05
APP_TRUST_SCORE__WEIGHTS__COMMUNITY=0.05

APP_TRUST_SCORE__TIERS__BRONZE_MAX=39
APP_TRUST_SCORE__TIERS__SILVER_MAX=59
APP_TRUST_SCORE__TIERS__GOLD_MAX=74
APP_TRUST_SCORE__TIERS__PLATINUM_MAX=100

APP_TRUST_SCORE__DECAY__INACTIVITY_THRESHOLD_DAYS=180
APP_TRUST_SCORE__DECAY__INACTIVITY_MONTHLY_PENALTY=2
APP_TRUST_SCORE__DECAY__PENALTY_HALVE_MONTHS=12
APP_TRUST_SCORE__DECAY__PENALTY_EXPIRE_MONTHS=24

APP_TRUST_SCORE__COLD_START__NEUTRAL_SCORE=50
APP_TRUST_SCORE__COLD_START__REVIEW_THRESHOLD=3

APP_TRUST_SCORE__NIGHTLY_JOB__ENABLED=true
APP_TRUST_SCORE__NIGHTLY_JOB__INTERVAL_SECONDS=86400
APP_TRUST_SCORE__NIGHTLY_JOB__BATCH_SIZE=1000