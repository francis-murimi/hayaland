# sqlx macros and tests read this by default.
DATABASE_URL=postgres://hayaland:password@127.0.0.1:5432/hayaland_test

# Application-specific config (overrides DATABASE_URL for the running API).
APP_DATABASE__URL=postgres://hayaland:password@127.0.0.1:5432/hayaland
APP_DATABASE__MAX_CONNECTIONS=10
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=8080
APP_LOG__LEVEL=info
APP_AUTH__SECRET=change-me-in-production
APP_AUTH__TOKEN_EXPIRY_SECONDS=86400
