  "query": "\n            SELECT id, email, username, password_hash, is_active, created_at, updated_at\n            FROM users\n            WHERE ($3::bool IS NULL OR is_active = $3)\n            ORDER BY created_at DESC\n            LIMIT $1 OFFSET $2\n            ",
